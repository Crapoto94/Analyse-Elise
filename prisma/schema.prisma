generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_SYSTEM")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String @default("user")
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  startTime  DateTime
  endTime    DateTime
  durationMs Int
  docsCount  Int
  tasksCount Int
  status     String
  message    String?
}

model AppConfig {
  key   String @id
  value String
}
