generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_SYSTEM")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model ApiRequestLog {
  id        Int      @id @default(autoincrement())
  endpoint  String
  method    String
  userEmail String?
  status    Int
  duration  Int
  timestamp DateTime @default(now())
}

model AppConfig {
  key   String @id
  value String
}
