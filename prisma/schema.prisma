generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FactDocument {
  id          Int      @id @default(autoincrement())
  externalId  Int      @unique
  createdDate DateTime
  theYear     Int
  level1      String?
  level2      String?
  level3      String?
  level4      String?
  level5      String?
}

model FactTask {
  id                           Int      @id @default(autoincrement())
  externalId                   Int      @unique
  documentId                   Int
  assignedToStructureElementId Int
  createdDate                  DateTime
}

model SyncLog {
  id         Int      @id @default(autoincrement())
  startTime  DateTime
  endTime    DateTime
  durationMs Int
  docsCount  Int
  tasksCount Int
  status     String
  message    String?
}
