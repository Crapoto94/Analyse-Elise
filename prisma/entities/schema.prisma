generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client/entities"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_ENTITIES")
}

// Local Document Model
model FactDocument {
  id          Int      @id @default(autoincrement())
  externalId  Int      @unique
  createdDate DateTime
  theYear     Int
  level1      String?
  level2      String?
  level3      String?
  level4      String?
  level5      String?
}

// Local Task Model
model FactTask {
  id                           Int      @id @default(autoincrement())
  externalId                   Int      @unique
  documentId                   Int
  assignedToStructureElementId Int
  createdDate                  DateTime
}

// OData Replica: Documents
model sync_FactDocument {
  id                             Int      @id @map("_id")
  sync_date                      String?  @map("_sync_date")
  external_id                    String?  @unique @map("_external_id")
  Id                             Float?
  Key                            String?
  UpdatedTimestamp               String?
  ArchivedByStructureElementId   Float?
  ArchivedByStructureElementName String?
  CreatedByStructureElementId    Float?
  CreatedByStructureElementName  String?
  DistributedByStructureElementId Float?
  DistributedByStructureElementName String?
  ClosedByStructureElementId     Float?
  ClosedByStructureElementName   String?
  SentByStructureElementId       Float?
  SentByStructureElementElementName String?
  DocumentDate                   String?
  RecordDate                     String?
  ClosedDate                     String?
  SentDate                       String?
  DistributedDate                String?
  ArchivedDate                   String?
  AlertDate                      String?
  CreatedDate                    String?
  UpdatedDate                    String?
  DueDate                        String?
  DirectionId                    Float?
  AcknowledgmentLevelId          Float?
  ConfidentialityLevelId         Float?
  StateId                        Float?
  PriorityId                     Float?
  TypeId                         Float?
  ClosureReasonId                Float?
  MediumId                       Float?
  Reported                       Int?
  DocumentIdentifier             String?
  Reference                      String?
  SenderContactCompanyId         String?
  SenderContactFunctionId        String?
  SenderContactIndividualId      String?
  RecipientContactCompanyId      String?
  RecipientContactFunctionId     String?
  RecipientContactIndividualId   String?

  @@map("sync_FactDocument")
}

// OData Replica: Tasks
model sync_FactTask {
  id                             Int      @id @map("_id")
  sync_date                      String?  @map("_sync_date")
  external_id                    String?  @unique @map("_external_id")
  Id                             Float?
  DocumentId                     Float?
  UpdatedTimestamp               String?
  TaskNumber                     Float?
  ActivatedDate                  String?
  RequestedDate                  String?
  ResponseDate                   String?
  ValidationDate                 String?
  ActionDate                     String?
  DueDate                        String?
  CreatedByStructureElementId    Float?
  CreatedByStructureElementName  String?
  ActivatedByStructureElementId  String?
  ActivatedByStructureElementName String?
  RequestedByStructureElementId  Float?
  RequestedByStructureElementName String?
  AssignedToStructureElementId   Float?
  AssignedToStructureElementName  String?
  ResponseByStructureElementId   Float?
  ResponseByStructureElementName String?
  ValidatedByStructureElementId  Float?
  ValidatedByStructureElementName String?
  ActionByStructureElementId     Float?
  ActionByStructureElementName   String?
  RequestActive                  Int?
  RequestIsValidationStep        Int?
  RequestIsStepValidated         Int?
  TaskProcessingTypeId           Float?
  TaskSubProcessingTypeId        Float?
  TaskCalculatedStateId          Float?
  ResponseState                  Float?
  ActionState                    Float?
  ValidationState                Float?

  @@map("sync_FactTask")
}

// OData Replica: Mediums
model sync_DimDocumentMedium {
  id          Int      @id @map("_id")
  sync_date   String?  @map("_sync_date")
  external_id String?  @unique @map("_external_id")
  Id          Float?
  Key         String?
  Label       String?
  LabelFrFr   String?

  @@map("sync_DimDocumentMedium")
}

// OData Replica: Types
model sync_DimDocumentType {
  id          Int      @id @map("_id")
  sync_date   String?  @map("_sync_date")
  external_id String?  @unique @map("_external_id")
  Id          Float?
  Key         String?
  Label       String?
  LabelFrFr   String?

  @@map("sync_DimDocumentType")
}

// OData Replica: States
model sync_DimDocumentState {
  id          Int      @id @map("_id")
  sync_date   String?  @map("_sync_date")
  external_id String?  @unique @map("_external_id")
  Id          Float?
  Key         String?
  Label       String?
  LabelFrFr   String?

  @@map("sync_DimDocumentState")
}

// OData Replica: Structure Hierarchy
model sync_DimStructureElementPath {
  id          Int      @id @map("_id")
  sync_date   String?  @map("_sync_date")
  external_id String?  @unique @map("_external_id")
  Path        String?
  Id_OData    Float?   @map("Id")
  Key         String?
  Level1      String?
  Level2      String?
  Level3      String?
  Level4      String?
  Level5      String?

  @@map("sync_DimStructureElementPath")
}

// OData Cache
model GenericRecord {
  id           Int      @id @default(autoincrement())
  entitySet    String
  externalId   String
  data         String
  lastSyncDate DateTime @default(now())

  @@unique([entitySet, externalId])
}
